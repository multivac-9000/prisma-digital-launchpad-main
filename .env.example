# Firebase (assessments de diagnóstico) — ver FIREBASE_SETUP.md
# Estas claves son PÚBLICAS (viajan al navegador); la seguridad real está en
# las reglas de Firestore. Copia este archivo a `.env` y pega tus valores.
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Envío del reporte de diagnóstico por correo (Brevo transaccional).
# SECRETAS y SOLO servidor (sin prefijo VITE_): nunca llegan al navegador.
# Ver la sección "Envío del reporte por correo" en FIREBASE_SETUP.md.
BREVO_API_KEY=
# Remitente verificado en Brevo (dominio/email validado). Opcionales:
BREVO_SENDER_EMAIL=prismadigital.io@gmail.com
BREVO_SENDER_NAME=Prisma Digital
